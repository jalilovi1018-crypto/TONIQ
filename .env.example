# VITE_OPENROUTER_API_KEY: Required for OpenRouter AI API calls from the Vite client.
VITE_OPENROUTER_API_KEY="your-openrouter-api-key-here"

# VITE_ANTHROPIC_API_KEY: Required for Anthropic Claude API calls from the Vite client.
VITE_ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# VITE_TONCONNECT_MANIFEST: Public manifest used by TON Connect clients.
VITE_TONCONNECT_MANIFEST="https://toniq.vercel.app/tonconnect-manifest.json"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
